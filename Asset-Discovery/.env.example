# Copy to .env and fill in. Required for Celery + API locks.

# Upstash: Dashboard → your database → "Connect" → pick "redis-cli" style URL:
#   rediss://default:XXXX@YOUR-ENDPOINT.upstash.io:6379
# Use that full string here (TLS). Do not use the REST URL for Celery.
REDIS_URL=rediss://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379

# How long celery-task-meta-* scan results stay in Redis (seconds). Default 3600 = 1h.
CELERY_RESULT_TTL_SEC=3600
