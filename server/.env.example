# Copy to server/.env and fill in.

MONGO_URI=mongodb://127.0.0.1:27017/bugchase
REDIS_URL=redis://127.0.0.1:6379
JWT_SECRET=change-me
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=change-me-refresh
JWT_REFRESH_EXPIRES_IN=30d
# Local dev: http://localhost:3000
# Production: https://bugchase-client.vercel.app
CLIENT_URL=http://localhost:3000
PORT=5000

# Google login for the separate support client. This is the Web Client ID from
# Google Cloud OAuth credentials. Must match support-client VITE_GOOGLE_CLIENT_ID.
# GOOGLE_CLIENT_ID=

# Asset Discovery (FastAPI on port 9000 — see Asset-Discovery/Readme.md)
ASSET_DISCOVERY_URL=http://127.0.0.1:9000

# Duplicate detection - MongoDB Atlas Search handles fast metadata filtering.
# The "duplicate_detection_index" is created automatically on server startup
# (idempotent — IndexAlreadyExists is treated as success). No additional
# credentials are required beyond MONGO_URI; Atlas Search runs inside the
# cluster.
# DUPLICATE_SEARCH_TOP_K=5

# Duplicate detection engine (FastAPI in ./duplicate_engine, default port 7870).
# Express POSTs the new report + hydrated Atlas Search candidates here. The engine
# performs prompt construction, security checks, calls Ollama (Foundation-Sec
# 8B Q4_K_M Reasoning) and returns a validated JSON verdict.
DUPLICATE_ENGINE_URL=http://127.0.0.1:7870/analyze-duplicate
# Shared secret. Leave empty for local dev; required in production. Must match
# the DUPLICATE_ENGINE_API_KEY set inside duplicate_engine/.
DUPLICATE_ENGINE_API_KEY=
DUPLICATE_LLM_TIMEOUT_MS=300000
DUPLICATE_LLM_ENABLED=true

# KYC engine (FastAPI). The browser POSTs CNIC + selfie to Express; Express
# uploads them to Cloudinary and forwards only the URLs to this service.
# Production: Hugging Face Space. Local dev: http://127.0.0.1:8000
KYC_ENGINE_URL=https://chshahzaib123-bugchase-kyc-engine.hf.space
# Per-request timeout (ms). HF Spaces can take 30-90s to wake from idle,
# so we default to 2 minutes and retry once on transient cold-start errors.
KYC_ENGINE_TIMEOUT_MS=120000

# CVSS triage engine (FastAPI in ./cvss_engine, default port 7860).
# After spam guard + duplicate detection, every new report is sent here
# for an AI-assisted CVSS v3.1 severity assessment. While the assessment is
# in progress, the report is visible to triagers but cannot be claimed.
CVSS_TRIAGE_URL=http://127.0.0.1:7860
CVSS_TRIAGE_TIMEOUT_MS=300000
CVSS_TRIAGE_ENABLED=true
# Optional override of the Ollama model key exposed by /models.
# CVSS_TRIAGE_MODEL_KEY=foundation-sec
