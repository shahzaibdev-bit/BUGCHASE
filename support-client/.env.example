# In local dev, leave this unset — Vite proxies /api to the main backend
# (http://localhost:5000) via vite.config.ts.
#
# In production, point this at the main BugChase API base URL so the support
# subdomain (e.g. support.bugchase.com) talks to the same backend, e.g.:
# VITE_API_URL=https://api.bugchase.com/api
# VITE_API_URL=

# Optional Google login. Use the same Web Client ID as server GOOGLE_CLIENT_ID.
# When unset, the support portal keeps the Google button disabled instead of
# pretending login works.
# VITE_GOOGLE_CLIENT_ID=
